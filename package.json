{
	"name": "dimsumlines",
	"displayName": "DimSumLines",
	"description": "Dim lines based on focus or regex patterns - focus mode dims all except focused line, regex mode dims matching lines",
	"version": "0.0.1",
	"engines": {
		"vscode": "^1.104.1"
	},
	"categories": [
		"Other"
	],
	"activationEvents": ["onStartupFinished"],
	"main": "./dist/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "dimsumlines.toggleDimming",
				"title": "DimSumLines: Toggle Dimming"
			},
			{
				"command": "dimsumlines.selectMode",
				"title": "DimSumLines: Select Mode"
			},
			{
				"command": "dimsumlines.addRegexPattern",
				"title": "DimSumLines: Add Regex Pattern"
			},
			{
				"command": "dimsumlines.clearRegexPatterns",
				"title": "DimSumLines: Clear Regex Patterns"
			},
			{
				"command": "dimsumlines.toggleInvertRegex",
				"title": "DimSumLines: Toggle Invert Regex"
			},
			{
				"command": "dimsumlines.manageRegexPatterns",
				"title": "DimSumLines: Manage Regex Patterns"
			}
		],
		"configuration": {
			"title": "Dim Sum Lines",
			"properties": {
				"dimsumlines.mode": {
					"type": "string",
					"enum": ["focus", "regex"],
					"default": "focus",
					"description": "Mode: 'focus' to dim all except focused line, 'regex' to dim lines matching patterns."
				},
				"dimsumlines.opacity": {
					"type": "number",
					"default": 0.3,
					"minimum": 0.1,
					"maximum": 0.9,
					"description": "Opacity level for dimmed lines (0.1 to 0.9)."
				},
				"dimsumlines.regexPatterns": {
					"type": "array",
					"default": [],
					"description": "Regex patterns to match lines to dim (used in regex mode)."
				},
				"dimsumlines.invertRegex": {
					"type": "boolean",
					"default": false,
					"description": "If true, dim lines that DON'T match the regex patterns."
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run package",
		"compile": "npm run check-types && npm run lint && node esbuild.js",
		"watch": "npm-run-all -p watch:*",
		"watch:esbuild": "node esbuild.js --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"package": "npm run check-types && npm run lint && node esbuild.js --production",
		"compile-tests": "tsc -p . --outDir out",
		"watch-tests": "tsc -p . -w --outDir out",
		"pretest": "npm run compile-tests && npm run compile && npm run lint",
		"check-types": "tsc --noEmit",
		"lint": "eslint src",
		"test": "vscode-test"
	},
	"devDependencies": {
		"@types/vscode": "^1.104.1",
		"@types/mocha": "^10.0.10",
		"@types/node": "22.x",
		"@typescript-eslint/eslint-plugin": "^8.45.0",
		"@typescript-eslint/parser": "^8.45.0",
		"eslint": "^9.36.0",
		"esbuild": "^0.25.10",
		"npm-run-all": "^4.1.5",
		"typescript": "^5.9.3",
		"@vscode/test-cli": "^0.0.11",
		"@vscode/test-electron": "^2.5.2"
	}
}
